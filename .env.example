# Пример переменных окружения для локальной разработки / Docker Compose

# --- Backend: SQLite файл (по умолчанию) ---
# В Docker Compose сохраняется в volume, см. compose.yaml
CYBER_VIS_DB_PATH=/data/login_attempts.db

# --- Порт API на хосте (docker compose) ---
# В контейнере API всегда 8000, наружу можно публиковать любой порт.
API_PORT=8000

# --- Desktop client: адрес API ---
CYBER_VIS_API_BASE=https://api.example.com

# --- HTTPS через Caddy ---
# Нужно для GitHub Pages или любого другого HTTPS-фронтенда.
# 1) Создайте DNS A-запись для api.<domain> -> IP сервера
# 2) Откройте на Windows-сервере порты 80 и 443
# 3) Запускайте compose с Caddy: docker compose -f compose.yaml -f compose.caddy.yaml up -d --build
CYBER_VIS_DOMAIN=api.example.com
