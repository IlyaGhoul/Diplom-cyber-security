# Example environment variables for local development or Docker Compose

# Backend SQLite file path.
# In Docker Compose this is stored inside the mounted data volume.
CYBER_VIS_DB_PATH=/data/login_attempts.db

# Host port published by compose for the FastAPI container.
# Inside the container the API always listens on 8000.
API_PORT=8000

# Client-facing API base URL.
# For local launch on the same machine use http://localhost/
# The launcher script can replace this with the current LAN IP automatically.
# For GitHub Pages production use https://api.<your-domain>/
CYBER_VIS_API_BASE=http://localhost/

# HTTPS domain used by Caddy.
# Example: api.cybattack.ru
CYBER_VIS_DOMAIN=api.example.com
